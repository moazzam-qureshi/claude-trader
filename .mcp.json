{
  "mcpServers": {
    "tsandwich": {
      "type": "http",
      "url": "http://mcp-server:8765/mcp"
    },
    "tradingview": {
      "type": "stdio",
      "command": "tradingview-mcp",
      "args": []
    },
    "binance": {
      "type": "stdio",
      "command": "binance-mcp",
      "args": [],
      "env": {
        "BINANCE_API_KEY": "${BINANCE_API_KEY}",
        "BINANCE_API_SECRET": "${BINANCE_API_SECRET}"
      }
    }
  }
}
